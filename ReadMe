━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECTION 1 — FIRST TIME SETUP (Do this ONCE only)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

STEP 1: Create Google Sheet
─────────────────────────────
  1. Go to sheets.google.com
  2. Create a new spreadsheet
  3. Name it: "itKINS POS Database"
  4. Copy the Sheet ID from URL:
     URL looks like: spreadsheets/d/THIS_IS_YOUR_ID/edit
     Copy that long ID and save it somewhere

STEP 2: Create Sheet Tabs (7 tabs required)
─────────────────────────────────────────────
  Create these tabs inside your spreadsheet:
  Tab 1: Items
  Tab 2: Categories
  Tab 3: Cashier
  Tab 4: Sales
  Tab 5: StockLog
  Tab 6: Customer
  Tab 7: Returns

  HOW TO CREATE TABS:
  Click the "+" button at bottom of Google Sheet
  Right-click tab → Rename

STEP 3: Add Headers to Each Tab
─────────────────────────────────
  Items tab headers (Row 1):
  Barcode | Category | Company | ItemName | Price | CostPrice | Discount | Stock | ExpiryDate

  Categories tab headers:
  CategoryName

  Cashier tab headers:
  Name | Username | PIN | Role

  Sales tab headers:
  BillNo | Date | Time | Cashier | GrandTotal | Discount | FBR | PaymentMethod | ItemsDetail | CustomerName | CustomerCell

  StockLog tab headers:
  Date | Barcode | ItemName | StockBefore | StockAfter | Reason

  Customer tab headers:
  Name | CellNo | BillNo

  Returns tab headers:
  ReturnNo | OrigBillNo | Date | Time | Cashier | Items | RefundAmount | Reason

  NOTE: OR just use Auto-Repair in Setup tab — it creates all headers automatically!

STEP 4: Set Up Apps Script
────────────────────────────
  1. In your Google Sheet: Extensions → Apps Script
  2. Delete ALL existing code in editor
  3. Open your POS app → Login as Admin
  4. Go to: Admin → Setup tab
  5. Click: "📥 Download Script v5 (.gs)"
  6. Open the downloaded file in Notepad
  7. Copy ALL the text
  8. Paste into Apps Script editor
  9. Click Save (Ctrl+S or the floppy disk icon)
  10. Click Deploy → New Deployment
  11. Click gear icon → Web App
  12. Set "Execute as": Me
  13. Set "Who has access": Anyone
  14. Click Deploy
  15. Copy the /exec URL (looks like: https://script.google.com/macros/s/LONG_ID/exec)
  16. Click Authorize/Allow when Google asks

STEP 5: Update POS Code Config
────────────────────────────────
  Open your POS code file and update these 3 lines at the top:

  const SHEET_ID = "YOUR_SHEET_ID_HERE";
  → Replace with your Sheet ID from Step 1

  const APPS_SCRIPT_URL = "YOUR_SCRIPT_URL_HERE";
  → Replace with your /exec URL from Step 4

  const SCRIPT_TOKEN = "itKINS@POS#2024$Secure!";
  → Change this to your own secret (use same in Apps Script!)

  IMPORTANT: The token must match EXACTLY in both places:
  - React code: const SCRIPT_TOKEN = "YourToken"
  - Apps Script: var SECRET_TOKEN = "YourToken"

STEP 6: Set Sheet Sharing
───────────────────────────
  1. Click "Share" button in Google Sheet (top right)
  2. Change "General access" to:
     → "Viewer" (anyone with link can view — needed for CSV loading)
  3. Remove any "Editor" access from others
  4. Your Gmail stays as Editor
  5. Click Done

  RESULT:
  ✅ POS can read data (Viewer access)
  ✅ No one can edit sheet directly
  ✅ All writes go through secured Apps Script with token

STEP 7: Add First Cashier
───────────────────────────
  1. Open your POS app
  2. Login with demo credentials: admin / 1234
  3. Go to Admin → Cashiers tab
  4. Click "+ Add User"
  5. Add your real admin account
  6. Add cashier accounts
  7. Your data saves to Google Sheet automatically

STEP 8: Add Categories and Items
──────────────────────────────────
  1. Admin → Categories tab → Add your categories
  2. Admin → Items tab → Add your items
  3. Each item needs: Barcode, Name, Price, Cost Price, Stock
  4. Expiry Date is optional but recommended for dairy/food items


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECTION 2 — DAILY OPERATIONS (Cashier Guide)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

HOW TO MAKE A SALE:
────────────────────
  1. Login with your Username and PIN
  2. On POS screen: scan barcode OR type item name in search box
  3. Item appears in cart
  4. Adjust quantity using +/- buttons or type in qty box
  5. Press ENTER to go back to search (add more items)
  6. Press ESC to clear search
  7. Add customer name and cell (optional)
  8. Enter payment amount in Cash or Card field
  9. If change shown = you paid correct amount
  10. Click "🖨 SAVE & PRINT" → Receipt prints automatically

HOW TO MAKE MULTIPLE BILLS AT ONCE:
─────────────────────────────────────
  1. Click "+ New Bill" tab at top
  2. Work on Bill 2 while Bill 1 waits
  3. Click between bill tabs to switch
  4. Each bill is independent

HOW TO APPLY BILL DISCOUNT:
────────────────────────────
  1. In totals area, find "Bill Discount %"
  2. Type a percentage (e.g., 10 for 10% off)
  3. Discount auto-calculates

HOW TO PROCESS RETURN/REFUND:
────────────────────────────────
  1. Click "↩ Return" button in top bar
  2. Type original Bill Number
  3. Click "Find Bill"
  4. Select items to return and quantities
  5. Choose reason
  6. Click "✓ Process Return & Print"
  7. Return receipt prints automatically
  8. Stock is automatically added back

HOW TO APPLY OLD REFUND TO NEW BILL:
───────────────────────────────────────
  1. On POS screen right panel: "↩ APPLY REFUND TO THIS BILL"
  2. Type the old bill number
  3. Click Find
  4. Enter refund amount
  5. Click Apply
  6. Refund deducted from new bill total

HOW TO USE CALCULATOR:
───────────────────────
  1. Click 🧮 button in top bar
  2. Calculator floats on screen
  3. You can drag it anywhere
  4. Keyboard works: numbers, +, -, *, /, Enter, Escape


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECTION 3 — ADMIN OPERATIONS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ADMIN TABS EXPLAINED:
──────────────────────
  📦 Items      → Add, edit, delete products
  🏷 Categories → Manage product categories
  👤 Cashiers   → Manage staff accounts and PINs
  📊 Sales      → View all transactions, filter by date/cashier
  ↩ Returns     → View all return/refund history
  💰 Profit     → Revenue, cost, profit analysis by category
  📉 Stock      → Stock levels, expiry dates, adjust quantities
  🧑 Customers  → Customer database with purchase history
  ⚙️ Setup      → Connection test, sync, script download

HOW TO ADD AN ITEM:
────────────────────
  1. Items tab → Click "+ Add Item"
  2. Fill in: Barcode, Item Name, Company
  3. Fill in: Selling Price, Cost Price
  4. Fill in: Discount (PKR per item, 0 if none)
  5. Fill in: Stock Quantity
  6. Set: Expiry Date (for food/dairy items)
  7. Select: Category
  8. Click "✓ Save"
  → Saves to Google Sheet automatically

HOW TO EDIT AN ITEM:
─────────────────────
  1. Items tab → Find item in list
  2. Click "Edit" button on that row
  3. Change any fields needed
  4. Click "✓ Save"

HOW TO DELETE AN ITEM:
───────────────────────
  1. Items tab → Find item
  2. Click "Del" button
  3. Confirm deletion

HOW TO ADJUST STOCK MANUALLY:
──────────────────────────────
  1. Stock tab → Find item
  2. Click "Set" button
  3. Type new stock number
  4. Press Enter or click ✓
  → Records in StockLog automatically

HOW TO VIEW PROFIT:
────────────────────
  1. Profit tab
  2. Filter by Date, Cashier, or Category
  3. See: Revenue, Cost, Net Profit, Margin %
  4. See: Profit by Category table
  5. See: Top 10 items by profit

  NOTE: Cost price must be set for each item for accurate profit!

HOW TO VIEW EXPIRY STATUS:
────────────────────────────
  1. Stock tab → Expiry alert banners show at top
  2. Red banner = EXPIRED items
  3. Orange banner = Expiring within 7 days
  4. Yellow banner = Expiring within 30 days
  5. Filter dropdown: select "⛔ Expired" or "🕐 Expiring Soon"

HOW TO DOWNLOAD STOCK PDF:
────────────────────────────
  1. Stock tab → Apply any filters you want
  2. Click "📄 Download PDF (X items)" button
  3. PDF opens in new window and prints
  4. PDF includes: barcode, name, price, stock, expiry, status


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECTION 4 — SYNC & CONNECTION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

HOW SYNC WORKS:
────────────────
  → On startup: Loads from local cache INSTANTLY (no waiting)
  → Then: Syncs from Google Sheet in background
  → Every 60 seconds: Auto-syncs if online
  → Status bar shows: Online/Offline + Last sync time
  → Click status bar: Force sync immediately

STATUS BAR COLORS:
───────────────────
  ✓ Green  = Live synced with Google Sheet
  💾 Blue  = Using local cache (offline recently synced data)
  ⟳ Yellow = Currently syncing
  ⚠ Red    = Error — could not reach Google Sheet
  ◉ Demo   = Running with demo data (not connected)

OFFLINE MODE:
──────────────
  If internet goes out:
  → POS continues working with cached data
  → Sales are saved locally AND queued for Google Sheet
  → When internet returns: queued sales auto-send to Sheet
  → You never lose a sale

HOW TO TEST CONNECTION:
────────────────────────
  1. Admin → Setup tab
  2. Click "▶ Run Test"
  3. See status of each sheet tab
  4. ✅ = Connected and headers OK
  5. ⚠️ = Connected but missing headers
  6. ❌ = Cannot reach sheet

HOW TO AUTO-REPAIR HEADERS:
─────────────────────────────
  1. Admin → Setup tab → Run Test first
  2. If any ⚠️ shown: Click "🔧 Auto-Repair"
  3. Waits 3 seconds then re-tests
  4. All missing headers added automatically


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECTION 5 — SECURITY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TOKEN SECURITY SYSTEM:
───────────────────────
  All write operations (save sale, add item, etc.) are protected
  by a secret token. Without the token, requests are blocked.

  Token is set in TWO places — must be IDENTICAL:
  1. React code: const SCRIPT_TOKEN = "YourToken"
  2. Apps Script: var SECRET_TOKEN = "YourToken"

  CHANGE YOUR TOKEN TO SOMETHING UNIQUE:
  Example: "MartBakery@Rawalpindi#2024$Ahmed!"
  Rule: Use letters, numbers, @, #, $, ! symbols

SHEET ACCESS LEVELS:
─────────────────────
  Your Gmail      → Editor (you can change everything)
  Everyone else   → Viewer only (CSV loading works, no editing)
  Apps Script     → Writes via token-protected API

  This means:
  ✅ POS loads data correctly
  ✅ No one can directly edit your sheet
  ✅ Fake requests without token = BLOCKED

IF YOU SUSPECT UNAUTHORIZED ACCESS:
─────────────────────────────────────
  1. Change SCRIPT_TOKEN in React code
  2. Change SECRET_TOKEN in Apps Script
  3. Redeploy Apps Script (new version)
  4. Update APPS_SCRIPT_URL in React code


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SECTION 6 — WHEN SOMETHING GOES WRONG
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

PROBLEM: POS not loading data / showing DEMO data
───────────────────────────────────────────────────
  CAUSE: Sheet ID or Script URL is wrong, or sheet is private
  FIX:
  1. Check SHEET_ID in code matches your Google Sheet URL
  2. Check APPS_SCRIPT_URL is correct /exec URL
  3. Make sure Sheet sharing is set to "Anyone with link - Viewer"
  4. Admin → Setup → Run Test to see exact error

PROBLEM: Sales not saving to Google Sheet
──────────────────────────────────────────
  CAUSE: Apps Script URL wrong, or token mismatch
  FIX:
  1. Check SCRIPT_TOKEN in React = SECRET_TOKEN in Apps Script
  2. Make sure Apps Script is deployed as Web App
  3. Check "Who has access" = Anyone
  4. Try: Admin → Setup → Run Test → check Script row

PROBLEM: Items/Sales show old data after changes
──────────────────────────────────────────────────
  FIX:
  1. Click the sync status indicator in top bar
  2. OR: Admin → Setup → 🔄 Sync Now
  3. Wait 5-10 seconds for fresh data

PROBLEM: Receipt not printing
───────────────────────────────
  CAUSE: Browser blocking popups
  FIX:
  1. Look for popup blocked icon in browser address bar
  2. Click it → Allow popups for this site
  3. Try printing again

PROBLEM: Apps Script Error after changes
──────────────────────────────────────────
  FIX:
  1. Admin → Setup → Download Script v5
  2. Go to Apps Script editor
  3. Delete ALL old code
  4. Paste new downloaded script
  5. Save → Deploy → New Version → Deploy
  6. Copy new /exec URL
  7. Update APPS_SCRIPT_URL in React code

PROBLEM: "Missing headers" warning in connection test
───────────────────────────────────────────────────────
  FIX:
  Option A: Click "🔧 Auto-Repair" in Setup tab
  Option B: Manually add missing column headers to Google Sheet

PROBLEM: IndexedDB / Cache issues
──────────────────────────────────
  FIX:
  1. Admin → Setup → Click "Clear Cache"
  2. Refresh the page
  3. Data will reload fresh from Google Sheet


